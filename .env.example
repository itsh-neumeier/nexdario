# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME=Nexdario
BIND_HOST=0.0.0.0
BIND_PORT=8080

# ─── Datenbank ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/nexdario.db

# ─── Verzeichnisse ───────────────────────────────────────────────────────────
DATA_DIR=/data
BACKUP_DIR=/data/backups
EXPORT_DIR=/data/exports
TEMPLATES_DIR=templates
STATIC_DIR=static

# ─── Admin-Initialkonto (nur beim ersten Start genutzt) ──────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_EMAIL=admin@example.com

# ─── Sicherheitsschlüssel (ÄNDERN VOR PRODUKTIVBETRIEB!) ────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string-before-production-use!!
SECRETS_ENCRYPTION_KEY=change-this-to-a-different-32-char-key

# ─── Backup ──────────────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTED=false
# BACKUP_ENCRYPTION_KEY=optional-separate-key-for-backup-encryption

# ─── Recovery Mode (NUR im Notfall aktivieren!) ──────────────────────────────
RECOVERY_MODE=false
# RECOVERY_TOKEN=min-32-chars-random-token-change-me

# ─── SMTP (optional) ─────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=user@example.com
# SMTP_PASSWORD=smtp-password
# SMTP_FROM=noreply@example.com
# SMTP_TLS=starttls
